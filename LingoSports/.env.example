DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
HOST=127.0.0.1
PORT=8002
API_URL=http://localhost:8002
ARCJET_KEY=
ARCJET_ENV=development
ARCJET_MODE=DRY_RUN
ARCJET_FAIL_OPEN=1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seeder tuning
DELAY_MS=250
SEED_RESET_BEFORE_RUN=1
SEED_RESET_ENABLED=1
SEED_NEW_MATCH_DELAY_MIN_MS=0
SEED_NEW_MATCH_DELAY_MAX_MS=0
SEED_FORCE_LIVE=1
SEED_MATCH_DURATION_MINUTES=120
SEED_SOURCE_LOCALE=en
SEED_TRANSLATION_QUALITY=fast
SEED_PRECOMPUTE_TRANSLATIONS=0
SEED_INCLUDE_GLOBAL_FAN_VIEW=0

# Lingo.dev runtime translation
LINGO_API_KEY=
LINGO_SOURCE_LOCALE=en
LINGO_TARGET_LOCALES=es,fr,de,hi,ar,ja,pt
LINGO_PRECOMPUTE_LOCALES=es,fr,de,hi,ar,ja,pt
LINGO_TRANSLATION_QUALITY=standard
LINGO_PRECOMPUTE_ON_INGEST=1
LINGO_DETECT_ALL_SOURCES=0
LINGO_REQUEST_CONCURRENCY=2
LINGO_PRECOMPUTE_CONCURRENCY=2
LINGO_BULK_TRANSLATION_CONCURRENCY=2
LINGO_PRECOMPUTE_QUEUE_CONCURRENCY=1
LINGO_PRECOMPUTE_QUEUE_MAX_PENDING=2000
LINGO_RETRY_ATTEMPTS=3
LINGO_RETRY_BASE_DELAY_MS=250
LINGO_RETRY_MAX_DELAY_MS=2000
LINGO_OUTAGE_FAILURE_THRESHOLD=6
LINGO_OUTAGE_COOLDOWN_MS=15000
LINGO_ERROR_LOG_WINDOW_MS=20000
LINGO_ERROR_LOG_MAX_PER_WINDOW=8
